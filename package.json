{
  "name": "@insannurjaman/uiqa",
  "version": "0.1.0",
  "description": "Open-source UI/UX QA CLI and GitHub Action for modern front-end teams.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "uiqa": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "docs",
    "examples/**/*.tsx",
    "examples/**/*.jsx",
    "action.yml",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "uiqa": "node dist/cli/index.js",
    "test": "vitest run",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ui",
    "ux",
    "qa",
    "cli",
    "github-action",
    "frontend",
    "react",
    "tsx",
    "accessibility",
    "design-system",
    "pull-request"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/insannurjaman/uiqa.git"
  },
  "bugs": {
    "url": "https://github.com/insannurjaman/uiqa/issues"
  },
  "homepage": "https://github.com/insannurjaman/uiqa#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@babel/parser": "^7.26.3",
    "@babel/traverse": "^7.26.4",
    "@babel/types": "^7.26.3",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@11.6.0"
}
